// StoryEcho — PostgreSQL (Supabase Postgres)
// Prisma ORM 스키마. Auth는 Supabase Auth, 비즈니스 데이터는 Route Handler + Prisma로 접근.

generator client {
  provider = "prisma-client-js"
}

/// PostgreSQL 15+ (Supabase managed). `DATABASE_URL`: PgBouncer pooler(6543), `DIRECT_URL`: direct(5432, migrate용).
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// 사용자 역할. guest=비로그인(device_id), member=로그인 회원, admin=운영·대시보드.
enum UserRole {
  guest  /// 비로그인·device_id (F16)
  member /// 로그인 회원 (일반 유저)
  admin  /// 운영·대시보드 접근
}

/// 이야기 공개 범위. 기본 private(나만 보기).
enum Visibility {
  private   /// 서랍·본인만 열람
  community /// 커뮤니티 feed 노출
}

/// 읽기·쓰기 화면 글자 크기 (F13). 기본 md.
enum FontSize {
  sm /// 소
  md /// 중 (기본)
  lg /// 대
}

/// StoryEcho 사용자. 게스트·회원 통합 테이블. Supabase Auth user.id와 PK 동기화.
model User {
  /// PK. UUID v4. Supabase Auth `auth.users.id`와 1:1 (가입 시 upsert).
  id                   String      @id @default(uuid()) @db.Uuid

  /// 게스트 식별용 기기 UUID. F16. unique, nullable(회원은 null 가능).
  deviceId             String?     @unique @map("device_id")

  /// 회원 이메일. Supabase Auth와 동일. unique, nullable(게스트는 null).
  email                String?     @unique

  /// guest | member | admin. 기본 guest.
  role                 UserRole    @default(guest) @map("role")

  /// Supabase Auth email_verified 연동. 커뮤니티 공개·IAP 시 true 필수.
  emailVerified        Boolean     @default(false) @map("email_verified")

  /// 커뮤니티·프로필 표시 이름 (F12). 게스트 포함. 전역 unique.
  nickname             String?     @unique

  /// 광고 제거 IAP 평생 유지 (F19). 회원 user_id에 저장.
  adFree               Boolean     @default(false) @map("ad_free")

  /// 글자 크기 설정 (F13). sm | md | lg, 기본 md.
  fontSize             FontSize    @default(md) @map("font_size")

  /// 같은 질문 받지 않기 (F14). ON 시 이미 받은 질문 제외. Echo는 예외.
  skipRepeatQuestions  Boolean     @default(false) @map("skip_repeat_questions")

  /// 알림 ON/OFF (F15). ON 시 20:00 로컬 리마인더 등.
  notificationsEnabled Boolean     @default(false) @map("notifications_enabled")

  /// 레코드 생성 시각 (UTC).
  createdAt            DateTime    @default(now()) @map("created_at")

  /// 게스트→회원 전환 시각. null이면 미전환.
  upgradedAt           DateTime?   @map("upgraded_at")

  stories               Story[]
  questionLogs          UserQuestionLog[]
  storyReports          StoryReport[]
  communityPosts        CommunityPost[]
  communityComments     CommunityComment[]
  storyComments         StoryComment[]
  communityReactions    CommunityReaction[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationActor")
  communityPostReports  CommunityPostReport[]
  pushTokens            PushToken[]

  @@map("users")
}

/// Expo Push 토큰 (모바일 FCM/APNs).
enum PushPlatform {
  android
  ios
}

model PushToken {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String       @unique @map("expo_push_token")
  platform      PushPlatform
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([userId])
  @@map("push_tokens")
}

/// 일일 질문 풀. F1 오늘의 질문 — KST 월·일 고정 (평년 365일).
model Question {
  /// PK. UUID v4. 시드: day-of-year 인코딩 ID.
  id        String   @id @default(uuid()) @db.Uuid

  /// 질문 본문 텍스트.
  text      String

  /// KST 기준 월 (1–12).
  month     Int

  /// KST 기준 일 (1–31). 윤년 2/29는 앱에서 2/28과 동일 질문.
  day       Int

  /// 질문 등록 시각 (UTC).
  createdAt DateTime @default(now()) @map("created_at")

  stories         Story[]
  questionLogs    UserQuestionLog[]
  communityPosts  CommunityPost[]

  @@unique([month, day])
  @@map("questions")
}

/// 사용자 이야기. 질문에 대한 텍스트·사진·공개범위·타임캡슐.
model Story {
  /// PK. UUID v4.
  id              String     @id @default(uuid()) @db.Uuid

  /// 작성자 FK → users.id.
  userId          String     @map("user_id") @db.Uuid

  /// 연결된 질문 FK → questions.id. nullable(질문 없이 작성 시).
  questionId      String?    @map("question_id") @db.Uuid

  /// 본문. 최대 5,000자 (기획 §4.1).
  bodyText        String     @map("body_text") @db.Text

  /// S3 URL/key 배열 JSON. 최대 8장 (F3).
  photoUrls       Json       @default("[]") @map("photo_urls")

  /// private(기본) | community. F8.
  visibility      Visibility @default(private)

  /// 타임캡슐 여부 (F6).
  isCapsule       Boolean    @default(false) @map("is_capsule")

  /// 타임캡슐 해제 시각. null이면 즉시 열람.
  unlockAt        DateTime?  @map("unlock_at")

  /// 봉인 중 여부. unlock_at 도래 전까지 true.
  isCapsuleActive Boolean    @default(false) @map("is_capsule_active")

  /// 신고 3건 누적 시 feed 자동 숨김 (moderation).
  hiddenFromFeed  Boolean    @default(false) @map("hidden_from_feed")

  /// 서랍 북마크 여부.
  isBookmarked    Boolean    @default(false) @map("is_bookmarked")

  /// 작성 시각 (UTC).
  createdAt       DateTime   @default(now()) @map("created_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question?     @relation(fields: [questionId], references: [id], onDelete: SetNull)
  reports       StoryReport[]
  comments      StoryComment[]
  notifications Notification[]

  @@index([userId, createdAt])
  @@index([visibility, hiddenFromFeed, createdAt(sort: Desc)])
  @@map("stories")
}

/// 사용자별 질문 노출 이력. 1년 Echo 트리거 기준일(shown_at).
model UserQuestionLog {
  /// PK. UUID v4.
  id         String   @id @default(uuid()) @db.Uuid

  /// 사용자 FK → users.id.
  userId     String   @map("user_id") @db.Uuid

  /// 질문 FK → questions.id.
  questionId String   @map("question_id") @db.Uuid

  /// 질문 최초 노출 시각. Echo: 동일 월·일 다음 해 재등장 기준.
  shownAt    DateTime @default(now()) @map("shown_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId, shownAt])
  @@index([userId, shownAt])
  @@index([userId, questionId])
  @@map("user_question_log")
}

/// 커뮤니티 이야기 신고. 동일 story_id 3건 → feed 숨김.
model StoryReport {
  /// PK. UUID v4.
  id             String   @id @default(uuid()) @db.Uuid

  /// 신고 대상 이야기 FK → stories.id.
  storyId        String   @map("story_id") @db.Uuid

  /// 신고자 FK → users.id.
  reporterUserId String   @map("reporter_user_id") @db.Uuid

  /// 신고 접수 시각 (UTC).
  createdAt      DateTime @default(now()) @map("created_at")

  story    Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  reporter User  @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@unique([storyId, reporterUserId])
  @@map("story_reports")
}

model StoryComment {
  id               String   @id @default(uuid()) @db.Uuid
  storyId          String   @map("story_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  parentId         String?  @map("parent_id") @db.Uuid
  bodyText         String   @map("body_text") @db.Text
  mentionedUserIds Json     @default("[]") @map("mentioned_user_ids")
  createdAt        DateTime @default(now()) @map("created_at")

  story   Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  StoryComment? @relation("StoryCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies StoryComment[] @relation("StoryCommentReplies")

  @@index([storyId, createdAt])
  @@index([parentId])
  @@map("story_comments")
}

/// 커뮤니티 토론 글 (서랍 Story와 분리).
enum CommunityReactionTargetType {
  post
  comment
  story
  story_comment
}

enum CommunityReactionEmoji {
  heart
  sad
  angry
  fire
  clap
}

enum NotificationType {
  comment_on_post
  reply_to_comment
  mention
  comment_on_public_story
  reply_to_story_comment
  daily_question_reminder
  capsule_unlocked
}

model CommunityPost {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  questionId     String?  @map("question_id") @db.Uuid
  bodyText       String   @map("body_text") @db.Text
  photoUrls      Json     @default("[]") @map("photo_urls")
  hiddenFromFeed Boolean  @default(false) @map("hidden_from_feed")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question?             @relation(fields: [questionId], references: [id], onDelete: SetNull)
  comments CommunityComment[]
  reports  CommunityPostReport[]

  @@index([hiddenFromFeed, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("community_posts")
}

model CommunityComment {
  id               String   @id @default(uuid()) @db.Uuid
  postId           String   @map("post_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  parentId         String?  @map("parent_id") @db.Uuid
  bodyText         String   @map("body_text") @db.Text
  mentionedUserIds Json     @default("[]") @map("mentioned_user_ids")
  createdAt        DateTime @default(now()) @map("created_at")

  post     CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   CommunityComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  CommunityComment[] @relation("CommentReplies")

  @@index([postId, createdAt])
  @@index([parentId])
  @@map("community_comments")
}

model CommunityReaction {
  id         String                    @id @default(uuid()) @db.Uuid
  targetType CommunityReactionTargetType @map("target_type")
  targetId   String                    @map("target_id") @db.Uuid
  userId     String                    @map("user_id") @db.Uuid
  emoji      CommunityReactionEmoji
  createdAt  DateTime                  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([targetType, targetId, userId])
  @@index([targetType, targetId])
  @@map("community_reactions")
}

model Notification {
  id              String           @id @default(uuid()) @db.Uuid
  recipientUserId String           @map("recipient_user_id") @db.Uuid
  actorUserId     String?          @map("actor_user_id") @db.Uuid
  type            NotificationType
  postId          String?          @map("post_id") @db.Uuid
  storyId         String?          @map("story_id") @db.Uuid
  commentId       String?          @map("comment_id") @db.Uuid
  readAt          DateTime?        @map("read_at")
  createdAt       DateTime         @default(now()) @map("created_at")

  recipient User   @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actor     User?  @relation("NotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  story     Story? @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([recipientUserId, type, storyId], map: "notifications_capsule_once")
  @@index([recipientUserId, readAt, createdAt(sort: Desc)])
  @@index([recipientUserId, type, createdAt(sort: Desc)])
  @@map("notifications")
}

model CommunityPostReport {
  id             String   @id @default(uuid()) @db.Uuid
  postId         String   @map("post_id") @db.Uuid
  reporterUserId String   @map("reporter_user_id") @db.Uuid
  reason         String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User          @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterUserId])
  @@map("community_post_reports")
}
