# Prisma CLI (packages/database/.env)
# Supabase Connect → ORMs → Prisma 에서 복사
DATABASE_URL=
DIRECT_URL=

# --- Seed (pnpm db:seed) ---
# 관리자 users row + (선택) Supabase Auth 동기화
SEED_ADMIN_USER_ID=a0000000-0000-4000-8000-000000000001
SEED_ADMIN_EMAIL=admin@storyecho.app
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NICKNAME=관리자

# Supabase Auth 동기화 시 필요 (루트 .env와 동일 값 복사)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
