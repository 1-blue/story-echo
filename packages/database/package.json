{
  "name": "@storyecho/database",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": "./src/client.ts",
    "./question-calendar": "./src/question-calendar.ts"
  },
  "scripts": {
    "generate:questions": "node scripts/import-questions-from-md.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "SEED_PROFILE=dev tsx src/seeds/run.ts",
    "db:seed:prod": "SEED_PROFILE=prod tsx src/seeds/run.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:unit": "vitest run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "ws": "^8.18.2",
    "prisma": "^6.9.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx src/seeds/run.ts"
  }
}
